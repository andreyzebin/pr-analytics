# Copy to .env and fill in your values, then: source .env

# Force UTF-8 mode (fixes Windows cp1251 issues with redirect to file)
export PYTHONUTF8=1

# ── Bitbucket Server ──────────────────────────────────────────────────────────

# Personal Access Token — required
export BB_TOKEN=...

# Alternatively, use the standard pr-agent variable name:
# export BITBUCKET_SERVER_BEARER_TOKEN=...

# ── TLS / SSL ─────────────────────────────────────────────────────────────────

# Custom CA bundle (corporate/self-signed cert).
# If not set, system CA certificates are used via truststore
# (automatically picks up corporate proxy CAs like CheckPoint).
# export REQUESTS_CA_BUNDLE=/path/to/ca-bundle.pem

# mTLS client certificate
# export BITBUCKET_SERVER_CLIENT_CERT=/path/to/client.pem

# ── LLM Judge ────────────────────────────────────────────────────────────────

# Anthropic (default if no base_url in config)
# export ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (or other OpenAI-compatible, set base_url in config)
# export DEEPSEEK_API_KEY=sk-...

# ── Proxy ─────────────────────────────────────────────────────────────────────

# export NO_PROXY="localhost,127.0.0.0/8,::1"
# export no_proxy="localhost,127.0.0.0/8,::1"
