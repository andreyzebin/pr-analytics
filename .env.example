# Copy to .env and fill in your values, then: source .env

# ── Bitbucket Server ──────────────────────────────────────────────────────────

# Personal Access Token — required
export BB_TOKEN=...

# Alternatively, use the standard pr-agent variable name:
# export BITBUCKET_SERVER_BEARER_TOKEN=...

# ── TLS / SSL ─────────────────────────────────────────────────────────────────

# Custom CA bundle (corporate/self-signed cert)
# export REQUESTS_CA_BUNDLE=/path/to/ca-bundle.pem

# mTLS client certificate
# export BITBUCKET_SERVER_CLIENT_CERT=/path/to/client.pem

# ── Proxy ─────────────────────────────────────────────────────────────────────

# export NO_PROXY="localhost,127.0.0.0/8,::1"
# export no_proxy="localhost,127.0.0.0/8,::1"
